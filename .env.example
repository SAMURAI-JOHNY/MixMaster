# Скопируйте в .env в корне репозитория для `docker compose up`.
# Секреты не коммитьте.

POSTGRES_PASSWORD=mixmaster_db_dev
MINIO_ROOT_PASSWORD=mixmaster_secret_change_me
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# CORS (через запятую). В compose по умолчанию уже включены localhost:8080 и :3000.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Публичный URL сайта (canonical, sitemap, Open Graph). Для продакшена укажите свой домен.
# PUBLIC_SITE_URL=https://example.com

# TheCocktailDB (опционально; по умолчанию публичный endpoint v1/1).
# COCKTAILDB_BASE_URL=https://www.thecocktaildb.com/api/json/v1/1
