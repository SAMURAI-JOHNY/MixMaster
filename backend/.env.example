# Локально без Docker — SQLite по умолчанию (без DATABASE_URL).
# С Docker/Postgres задайте DATABASE_URL и см. корневой .env.example.

# DATABASE_URL=postgresql://mixmaster:password@localhost:5432/mixmaster
JWT_SECRET_KEY=change-me-in-production-min-32-chars
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://127.0.0.1:9000
# Для backend в Docker оставьте S3_ENDPOINT_URL=http://minio:9000 и задайте адрес для браузера:
# S3_PRESIGN_ENDPOINT_URL=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=mixmaster
S3_ACCESS_KEY_ID=mixmaster
S3_SECRET_ACCESS_KEY=mixmaster_secret_change_me

S3_PRESIGNED_EXPIRES=900
S3_MAX_FILE_SIZE_MB=8
